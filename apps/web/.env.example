# Supabase (required)
# Local values: `npx supabase status` after `npm run db:start`.
# Production values: Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI assistant (optional; /assistant is disabled without it)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Google Calendar integration (optional; Settings -> Calendar is disabled
# without it). OAuth client from Google Cloud Console with the Calendar API
# enabled; redirect URI: <site-origin>/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
