{
  "name": "gtd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w @gtd/shared && npm run build -w web",
    "lint": "npm run lint -w web",
    "test": "npm run test -w @gtd/shared",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "supabase": "^2.0.0"
  }
}
